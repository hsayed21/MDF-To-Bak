<Window x:Class="MdfToBakConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MDF to BAK Converter" Height="700" Width="850" MinHeight="560" MinWidth="720">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

    <GroupBox Grid.Row="0" Grid.ColumnSpan="2" Header="SQL Server LocalDB engine" Margin="0,0,0,12">
      <StackPanel Margin="10">
        <WrapPanel>
          <RadioButton x:Name="Sql2012" Content="SQL Server 2012 LocalDB (11.0)" Tag="2012" Margin="4" IsChecked="True" Checked="EngineChanged"/>
          <RadioButton x:Name="Sql2014" Content="SQL Server 2014 LocalDB (12.0)" Tag="2014" Margin="4" Checked="EngineChanged"/>
          <RadioButton x:Name="Sql2016" Content="SQL Server 2016 LocalDB (13.0)" Tag="2016" Margin="4" Checked="EngineChanged"/>
          <RadioButton x:Name="Sql2019" Content="SQL Server 2019 LocalDB (15.0)" Tag="2019" Margin="4" Checked="EngineChanged"/>
          <RadioButton x:Name="Sql2022" Content="SQL Server 2022 LocalDB (16.0)" Tag="2022" Margin="4" Checked="EngineChanged"/>
        </WrapPanel>
        <StackPanel Orientation="Horizontal" Margin="4,8,4,0">
          <TextBlock x:Name="InstallationStatus" VerticalAlignment="Center" Foreground="DarkSlateGray">Checking LocalDB installation…</TextBlock>
          <Button x:Name="InstallButton" Content="Install" Click="Install_Click" Visibility="Collapsed" Margin="12,0,0,0"/>
        </StackPanel>
      </StackPanel>
    </GroupBox>

    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="MDF file:"/>
    <DockPanel Grid.Row="1" Grid.Column="1"><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseMdf_Click"/><TextBox x:Name="MdfPath" TextChanged="PathChanged"/></DockPanel>
    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="LDF file (optional):"/>
    <DockPanel Grid.Row="2" Grid.Column="1"><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseLdf_Click"/><TextBox x:Name="LdfPath" TextChanged="PathChanged"/></DockPanel>
    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Output BAK:"/>
    <DockPanel Grid.Row="3" Grid.Column="1"><Button DockPanel.Dock="Right" Content="Browse…" Click="BrowseBak_Click"/><TextBox x:Name="BakPath" TextChanged="PathChanged"/></DockPanel>

    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,10">
      <Button x:Name="ConvertButton" Content="Convert to BAK" Click="Convert_Click" IsEnabled="False"/>
      <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click" IsEnabled="False"/>
      <ProgressBar x:Name="Progress" Width="250" Height="18" Margin="14,7" IsIndeterminate="False"/>
      <TextBlock x:Name="OperationStatus" VerticalAlignment="Center" Text="Select an MDF file and output path."/>
    </StackPanel>

    <GroupBox Grid.Row="5" Grid.ColumnSpan="2" Header="Technical log">
      <TextBox x:Name="LogBox" Margin="8" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
    </GroupBox>
  </Grid>
</Window>
